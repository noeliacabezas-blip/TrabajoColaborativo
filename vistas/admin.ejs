<!DOCTYPE html>
<html lang="es">
	<head>		
		<%-include('parciales/head') %>
	</head>
	<body>
		<header class="sticky-top bg-white border-bottom">
			<%-include('parciales/header') %>
		</header>
		<main class="container py-4">
			<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
				<div>
					<h1 class="mb-1">Panel de administración</h1>
					<p id="admin-bienvenida" class="text-muted mb-0">Cargando sesión...</p>
				</div>
				<button id="btnNuevoCurso" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#modalCurso">Nuevo curso</button>
			</div>

			<section class="card shadow-sm mb-4">
				<div class="card-body">
					<h2 class="h4">Gestión de cursos</h2>
					<p class="text-muted">Desde aquí puedes crear, editar y eliminar cursos del catálogo.</p>
					<div class="table-responsive">
						<table class="table table-striped table-hover align-middle">
							<thead class="table-primary">
								<tr>
									<th>Título</th>
									<th>Categoría</th>
									<th>Nivel</th>
									<th>Duración</th>
									<th>Profesor</th>
									<th>Temario</th>
									<th>Acciones</th>
								</tr>
							</thead>
							<tbody id="tabla-admin-cursos">
								<tr><td colspan="7" class="text-center">Cargando cursos...</td></tr>
							</tbody>
						</table>
					</div>
				</div>
			</section>
		</main>

		<div class="modal fade" id="modalCurso" tabindex="-1" aria-hidden="true">
			<div class="modal-dialog modal-lg modal-dialog-scrollable">
				<div class="modal-content">
					<div class="modal-header fondo_corporativo_azul_marino text-white">
						<h2 id="modalCursoLabel" class="modal-title h5 text-white">Nuevo curso</h2>
						<button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Cerrar"></button>
					</div>
					<div class="modal-body">
						<form id="form-admin-curso">
							<input type="hidden" id="cursoId">
							<div class="row g-3">
								<div class="col-md-8">
									<label for="titulo" class="form-label">Título</label>
									<input type="text" id="titulo" class="form-control" required>
								</div>
								<div class="col-md-4">
									<label for="duracion" class="form-label">Duración</label>
									<input type="text" id="duracion" class="form-control" required>
								</div>
								<div class="col-md-4">
									<label for="categoria" class="form-label">Categoría</label>
									<input type="text" id="categoria" class="form-control" required>
								</div>
								<div class="col-md-4">
									<label for="nivel" class="form-label">Nivel</label>
									<select id="nivel" class="form-select" required>
										<option value="">Selecciona nivel</option>
										<option value="Básico">Básico</option>
										<option value="Medio">Medio</option>
										<option value="Avanzado">Avanzado</option>
									</select>
								</div>
								<div class="col-md-4">
									<label for="profesorId" class="form-label">Profesor</label>
									<select id="profesorId" class="form-select" required></select>
								</div>
								<div class="col-12">
									<label for="imagen" class="form-label">Ruta de la imagen</label>
									<input type="text" id="imagen" class="form-control" placeholder="./img/curso_x_logo.jpg" required>
								</div>
								<div class="col-12">
									<label for="descripcion" class="form-label">Descripción</label>
									<textarea id="descripcion" class="form-control" rows="5" required></textarea>
								</div>
								<div class="col-12">
									<label for="temario" class="form-label">Temario (un tema por línea)</label>
									<textarea id="temario" class="form-control" rows="6"></textarea>
								</div>
							</div>
						</form>
					</div>
					<div class="modal-footer">
						<button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
						<button id="btnGuardarCurso" type="submit" form="form-admin-curso" class="btn btn-primary">Crear curso</button>
					</div>
				</div>
			</div>
		</div>
		<footer class="fondo_corporativo_azul_marino text-white py-2 mt-2">
			<%-include('parciales/footer') %>				
		</footer>
		<%-include('parciales/modales_scripts') %>	
		<script src="/scripts/scr_admin.js"></script>
	</body>
</html>
